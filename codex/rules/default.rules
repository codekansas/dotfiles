# General command approval rules for Codex.
#
# Use `allow` only for low-risk inspection commands. Prefer `auto_review` for
# commands that mutate the workspace, install dependencies, publish code, or
# touch external services, so routine development can proceed without waiting
# for a manual approval prompt.

# Git inspection and synchronization.
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")
prefix_rule(pattern=["git", "branch"], decision="allow")
prefix_rule(pattern=["git", "rev-parse"], decision="allow")
prefix_rule(pattern=["git", "ls-files"], decision="allow")
prefix_rule(pattern=["git", "grep"], decision="allow")
prefix_rule(pattern=["git", "remote"], decision="allow")
prefix_rule(pattern=["git", "describe"], decision="allow")
prefix_rule(pattern=["git", "blame"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="auto_review")
prefix_rule(pattern=["git", "pull", "--ff-only"], decision="auto_review")

# Git workspace and publishing operations.
prefix_rule(pattern=["git", "add"], decision="auto_review")
prefix_rule(pattern=["git", "commit"], decision="auto_review")
prefix_rule(pattern=["git", "checkout", "-b"], decision="auto_review")
prefix_rule(pattern=["git", "switch", "-c"], decision="auto_review")
prefix_rule(pattern=["git", "merge"], decision="auto_review")
prefix_rule(pattern=["git", "rebase"], decision="auto_review")
prefix_rule(pattern=["git", "cherry-pick"], decision="auto_review")
prefix_rule(pattern=["git", "tag"], decision="auto_review")
prefix_rule(pattern=["git", "push"], decision="auto_review")

# GitHub CLI read paths and common PR actions.
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")
prefix_rule(pattern=["gh", "issue", "view"], decision="allow")
prefix_rule(pattern=["gh", "issue", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "diff"], decision="allow")
prefix_rule(pattern=["gh", "pr", "status"], decision="allow")
prefix_rule(pattern=["gh", "pr", "checks"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")
prefix_rule(pattern=["gh", "run", "list"], decision="allow")
prefix_rule(pattern=["gh", "workflow", "view"], decision="allow")
prefix_rule(pattern=["gh", "workflow", "list"], decision="allow")
prefix_rule(pattern=["gh", "pr", "create"], decision="auto_review")
prefix_rule(pattern=["gh", "pr", "edit"], decision="auto_review")
prefix_rule(pattern=["gh", "pr", "comment"], decision="auto_review")
prefix_rule(pattern=["gh", "pr", "review"], decision="auto_review")
prefix_rule(pattern=["gh", "pr", "merge"], decision="auto_review")
prefix_rule(pattern=["gh", "issue", "create"], decision="auto_review")
prefix_rule(pattern=["gh", "issue", "comment"], decision="auto_review")
prefix_rule(pattern=["gh", "run", "watch"], decision="auto_review")

# Local file and repo maintenance.
prefix_rule(pattern=["mkdir", "-p"], decision="auto_review")
prefix_rule(pattern=["touch"], decision="auto_review")
prefix_rule(pattern=["cp"], decision="auto_review")
prefix_rule(pattern=["mv"], decision="auto_review")
prefix_rule(pattern=["ln", "-s"], decision="auto_review")
prefix_rule(pattern=["chmod"], decision="auto_review")
prefix_rule(pattern=["rm", "-f"], decision="auto_review")

# Local scripts and interpreters.
prefix_rule(pattern=["./install"], decision="auto_review")
prefix_rule(pattern=["bash"], decision="auto_review")
prefix_rule(pattern=["zsh"], decision="auto_review")
prefix_rule(pattern=["sh"], decision="auto_review")
prefix_rule(pattern=["python"], decision="auto_review")
prefix_rule(pattern=["python3"], decision="auto_review")
prefix_rule(pattern=["uvx"], decision="auto_review")

# Project task runners, build tools, and test commands.
prefix_rule(pattern=["make"], decision="auto_review")
prefix_rule(pattern=["just"], decision="auto_review")
prefix_rule(pattern=["task"], decision="auto_review")
prefix_rule(pattern=["ninja"], decision="auto_review")
prefix_rule(pattern=["cmake"], decision="auto_review")
prefix_rule(pattern=["bazel", "build"], decision="auto_review")
prefix_rule(pattern=["bazel", "test"], decision="auto_review")
prefix_rule(pattern=["buck2"], decision="auto_review")
prefix_rule(pattern=["docker", "build"], decision="auto_review")
prefix_rule(pattern=["docker", "compose"], decision="auto_review")
prefix_rule(pattern=["docker-compose"], decision="auto_review")

# JavaScript and TypeScript workflows.
prefix_rule(pattern=["npm", "install"], decision="auto_review")
prefix_rule(pattern=["npm", "ci"], decision="auto_review")
prefix_rule(pattern=["npm", "run"], decision="auto_review")
prefix_rule(pattern=["npm", "test"], decision="auto_review")
prefix_rule(pattern=["npx"], decision="auto_review")
prefix_rule(pattern=["pnpm", "install"], decision="auto_review")
prefix_rule(pattern=["pnpm", "run"], decision="auto_review")
prefix_rule(pattern=["pnpm", "test"], decision="auto_review")
prefix_rule(pattern=["pnpm", "exec"], decision="auto_review")
prefix_rule(pattern=["yarn", "install"], decision="auto_review")
prefix_rule(pattern=["yarn", "run"], decision="auto_review")
prefix_rule(pattern=["yarn", "test"], decision="auto_review")
prefix_rule(pattern=["yarn", "exec"], decision="auto_review")
prefix_rule(pattern=["bun", "install"], decision="auto_review")
prefix_rule(pattern=["bun", "run"], decision="auto_review")
prefix_rule(pattern=["bun", "test"], decision="auto_review")
prefix_rule(pattern=["bunx"], decision="auto_review")
prefix_rule(pattern=["node", "--test"], decision="auto_review")
prefix_rule(pattern=["tsc"], decision="auto_review")
prefix_rule(pattern=["eslint"], decision="auto_review")
prefix_rule(pattern=["prettier"], decision="auto_review")
prefix_rule(pattern=["vitest"], decision="auto_review")
prefix_rule(pattern=["jest"], decision="auto_review")
prefix_rule(pattern=["playwright"], decision="auto_review")

# Python workflows.
prefix_rule(pattern=["uv", "run"], decision="auto_review")
prefix_rule(pattern=["uv", "sync"], decision="auto_review")
prefix_rule(pattern=["uv", "add"], decision="auto_review")
prefix_rule(pattern=["uv", "remove"], decision="auto_review")
prefix_rule(pattern=["uv", "pip"], decision="auto_review")
prefix_rule(pattern=["python", "-m", "pytest"], decision="auto_review")
prefix_rule(pattern=["python3", "-m", "pytest"], decision="auto_review")
prefix_rule(pattern=["pytest"], decision="auto_review")
prefix_rule(pattern=["ruff", "check"], decision="auto_review")
prefix_rule(pattern=["ruff", "format"], decision="auto_review")
prefix_rule(pattern=["ty", "lint"], decision="auto_review")
prefix_rule(pattern=["basedpyright"], decision="auto_review")
prefix_rule(pattern=["pyright"], decision="auto_review")
prefix_rule(pattern=["mypy"], decision="auto_review")
prefix_rule(pattern=["pip", "install"], decision="auto_review")
prefix_rule(pattern=["pip3", "install"], decision="auto_review")

# Rust, Go, Swift, and Apple-platform workflows.
prefix_rule(pattern=["cargo", "build"], decision="auto_review")
prefix_rule(pattern=["cargo", "check"], decision="auto_review")
prefix_rule(pattern=["cargo", "clippy"], decision="auto_review")
prefix_rule(pattern=["cargo", "fmt"], decision="auto_review")
prefix_rule(pattern=["cargo", "test"], decision="auto_review")
prefix_rule(pattern=["go", "build"], decision="auto_review")
prefix_rule(pattern=["go", "test"], decision="auto_review")
prefix_rule(pattern=["go", "tool"], decision="auto_review")
prefix_rule(pattern=["go", "mod"], decision="auto_review")
prefix_rule(pattern=["swift", "build"], decision="auto_review")
prefix_rule(pattern=["swift", "test"], decision="auto_review")
prefix_rule(pattern=["swift", "format"], decision="auto_review")
prefix_rule(pattern=["xcodebuild"], decision="auto_review")

# Bolte CLI
prefix_rule(pattern=["bolte", "wiki"], decision="allow")
prefix_rule(pattern=["bolte", "path"], decision="allow")
prefix_rule(pattern=["bolte", "--help"], decision="allow")
